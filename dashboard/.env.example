# Dashboard inherits server config; values here are only used for local Tauri/dev tooling
# that talks directly to provider APIs (typescript checks, scaffolding scripts, etc.).
# In production the dashboard reads everything via the server API.

# ─── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=my-org

# ─── Cloudflare ───────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ─── R2 ───────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ops-builds
R2_ENDPOINT=

# ─── Webhooks ─────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
WEBHOOK_URL=
