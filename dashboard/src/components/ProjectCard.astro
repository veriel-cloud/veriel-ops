---
import type { Project } from "@/lib/types";
import EnvironmentBadge from "./EnvironmentBadge.astro";
import CoverageBar from "./CoverageBar.astro";
import StatusDot from "./StatusDot.astro";
import { timeAgo } from "@/lib/data";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const typeLabels: Record<string, string> = {
  "astro-static": "Astro Static",
  "astro-ssr": "Astro SSR",
  "react-spa": "React SPA",
  "backend-worker": "Worker",
};

const typeColors: Record<string, string> = {
  "astro-static": "bg-orange-500/15 text-orange-400",
  "astro-ssr": "bg-orange-500/15 text-orange-400",
  "react-spa": "bg-cyan-500/15 text-cyan-400",
  "backend-worker": "bg-purple-500/15 text-purple-400",
};

const mostRecentDeploy = Object.values(project.environments)
  .filter((env) => env.lastDeployAt)
  .sort((a, b) => new Date(b.lastDeployAt!).getTime() - new Date(a.lastDeployAt!).getTime())[0];
---

<a href={`/projects/${project.name}`} class="card-hover block p-5 group">
  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-surface-700 flex items-center justify-center group-hover:bg-surface-600 transition-colors">
        <span class="text-lg font-bold text-surface-300">
          {project.name.charAt(0).toUpperCase()}
        </span>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-white group-hover:text-brand-400 transition-colors">
          {project.name}
        </h3>
        <p class="text-xs text-surface-500">{project.domain}</p>
      </div>
    </div>
    <span class:list={["badge", typeColors[project.type]]}>
      {typeLabels[project.type]}
    </span>
  </div>

  <!-- Environments -->
  <div class="flex items-center gap-2 mb-4">
    {(["des", "pre", "pro"] as const).map((env) => (
      <EnvironmentBadge
        environment={env}
        status={project.environments[env].status}
        version={project.environments[env].version}
        compact
      />
    ))}
  </div>

  <!-- Coverage -->
  <div class="mb-3">
    <CoverageBar percentage={project.coverage} size="sm" />
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between text-xs text-surface-500">
    <span class="flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 3l5 5l-5 5" /><path d="M21 8h-12a4 4 0 1 0 0 8h4" />
      </svg>
      {project.repo}
    </span>
    {mostRecentDeploy?.lastDeployAt && (
      <span>{timeAgo(mostRecentDeploy.lastDeployAt)}</span>
    )}
  </div>
</a>
