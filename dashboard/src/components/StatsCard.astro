---
interface Props {
  label: string;
  value: string | number;
  suffix?: string;
  trend?: "up" | "down" | "neutral";
  trendValue?: string;
  variant?: "default" | "success" | "warning" | "danger";
}

const { label, value, suffix, trend, trendValue, variant = "default" } = Astro.props;

const variantColors = {
  default: "from-brand-600/10 to-brand-600/5 border-brand-600/20",
  success: "from-emerald-600/10 to-emerald-600/5 border-emerald-600/20",
  warning: "from-amber-600/10 to-amber-600/5 border-amber-600/20",
  danger: "from-red-600/10 to-red-600/5 border-red-600/20",
};

const iconColors = {
  default: "text-brand-400",
  success: "text-emerald-400",
  warning: "text-amber-400",
  danger: "text-red-400",
};
---

<div class:list={[
  "rounded-xl border bg-gradient-to-br p-5",
  variantColors[variant],
]}>
  <p class="text-xs font-medium text-surface-400 uppercase tracking-wider">{label}</p>
  <div class="mt-2 flex items-baseline gap-2">
    <span class:list={["text-3xl font-bold text-white"]}>{value}</span>
    {suffix && <span class="text-sm text-surface-400">{suffix}</span>}
  </div>
  {trend && trendValue && (
    <div class="mt-2 flex items-center gap-1">
      {trend === "up" && (
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 17l6 -6l4 4l8 -8" /><path d="M14 7l7 0l0 7" />
        </svg>
      )}
      {trend === "down" && (
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 7l6 6l4 -4l8 8" /><path d="M21 10l0 7l-7 0" />
        </svg>
      )}
      <span class:list={[
        "text-xs font-medium",
        trend === "up" ? "text-emerald-400" : trend === "down" ? "text-red-400" : "text-surface-400",
      ]}>
        {trendValue}
      </span>
    </div>
  )}
</div>
