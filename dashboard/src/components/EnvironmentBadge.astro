---
import type { Environment, HealthStatus } from "@/lib/types";

interface Props {
  environment: Environment;
  status: HealthStatus;
  version?: string | null;
  compact?: boolean;
}

const { environment, status, version, compact = false } = Astro.props;

const envLabels: Record<Environment, string> = {
  des: "DES",
  pre: "PRE",
  pro: "PRO",
};

const envColors: Record<Environment, string> = {
  des: "bg-sky-500/15 text-sky-400 border-sky-500/30",
  pre: "bg-amber-500/15 text-amber-400 border-amber-500/30",
  pro: "bg-emerald-500/15 text-emerald-400 border-emerald-500/30",
};

const statusDots: Record<HealthStatus, string> = {
  healthy: "bg-emerald-400",
  degraded: "bg-amber-400",
  down: "bg-red-400",
  idle: "bg-surface-500",
};
---

<div class:list={[
  "inline-flex items-center gap-2 rounded-lg border px-3 py-1.5",
  envColors[environment],
  compact && "px-2 py-1",
]}>
  <span class:list={["w-2 h-2 rounded-full", statusDots[status]]} />
  <span class:list={["font-semibold", compact ? "text-xs" : "text-xs"]}>
    {envLabels[environment]}
  </span>
  {version && (
    <span class="text-xs opacity-70">{version}</span>
  )}
</div>
