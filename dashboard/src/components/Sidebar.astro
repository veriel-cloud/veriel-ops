---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  {
    label: "Dashboard",
    href: "/",
    icon: "dashboard",
  },
  {
    label: "Proyectos",
    href: "/projects",
    icon: "folders",
  },
  {
    label: "Deploys",
    href: "/deploys",
    icon: "rocket",
  },
  {
    label: "Settings",
    href: "/settings",
    icon: "settings",
  },
];

function isActive(href: string, current: string): boolean {
  if (href === "/") return current === "/";
  return current.startsWith(href);
}
---

<aside class="fixed top-0 left-0 z-40 h-screen w-64 bg-surface-900 border-r border-surface-700 flex flex-col">
  <!-- Logo -->
  <div class="flex items-center gap-3 px-6 py-5 border-b border-surface-700">
    <div class="w-9 h-9 rounded-lg bg-brand-600 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 7l6 -3l6 3l6 -3v13l-6 3l-6 -3l-6 3v-13" />
        <path d="M9 4v13" />
        <path d="M15 7v13" />
      </svg>
    </div>
    <div>
      <span class="text-base font-bold text-white">veriel-ops</span>
      <span class="block text-xs text-surface-500">v0.1.0</span>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    {navItems.map((item) => {
      const active = isActive(item.href, currentPath);
      return (
        <a
          href={item.href}
          class:list={[
            "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200",
            active
              ? "bg-brand-600/15 text-brand-400 border border-brand-600/30"
              : "text-surface-400 hover:text-surface-200 hover:bg-surface-800 border border-transparent",
          ]}
        >
          {item.icon === "dashboard" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h6v8h-6z" /><path d="M4 16h6v4h-6z" /><path d="M14 12h6v8h-6z" /><path d="M14 4h6v4h-6z" />
            </svg>
          )}
          {item.icon === "folders" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 4h3l2 2h5a2 2 0 0 1 2 2v7a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-9a2 2 0 0 1 2 -2" />
            </svg>
          )}
          {item.icon === "rocket" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3" />
              <path d="M7 14a6 6 0 0 0 -3 6a6 6 0 0 0 6 -3" />
              <circle cx="15" cy="9" r="1" />
            </svg>
          )}
          {item.icon === "settings" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.066 2.573c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.573 1.066c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.066 -2.573c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37a1.724 1.724 0 0 0 2.573 -1.066z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
          )}
          <span>{item.label}</span>
        </a>
      );
    })}
  </nav>

  <!-- Footer -->
  <div class="px-4 py-4 border-t border-surface-700">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-brand-600/20 flex items-center justify-center">
        <span class="text-xs font-bold text-brand-400">VD</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-surface-200 truncate">veriel-dev</p>
        <p class="text-xs text-surface-500">veriel.dev</p>
      </div>
    </div>
  </div>
</aside>
