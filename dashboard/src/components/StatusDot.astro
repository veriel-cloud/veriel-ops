---
import type { HealthStatus } from "@/lib/types";

interface Props {
  status: HealthStatus;
  pulse?: boolean;
}

const { status, pulse = false } = Astro.props;

const colors: Record<HealthStatus, string> = {
  healthy: "bg-emerald-400",
  degraded: "bg-amber-400",
  down: "bg-red-400",
  idle: "bg-surface-500",
};

const labels: Record<HealthStatus, string> = {
  healthy: "Operativo",
  degraded: "Degradado",
  down: "Caido",
  idle: "Inactivo",
};
---

<span class="inline-flex items-center gap-1.5" title={labels[status]}>
  <span class="relative flex h-2.5 w-2.5">
    {pulse && status === "healthy" && (
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" />
    )}
    <span class:list={["relative inline-flex rounded-full h-2.5 w-2.5", colors[status]]} />
  </span>
</span>
