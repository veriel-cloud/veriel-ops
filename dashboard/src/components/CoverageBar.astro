---
interface Props {
  percentage: number;
  threshold?: number;
  showLabel?: boolean;
  size?: "sm" | "md" | "lg";
}

const { percentage, threshold = 80, showLabel = true, size = "md" } = Astro.props;

const isAboveThreshold = percentage >= threshold;

const barColor = isAboveThreshold
  ? percentage >= 90
    ? "bg-emerald-500"
    : "bg-brand-500"
  : "bg-red-500";

const textColor = isAboveThreshold
  ? percentage >= 90
    ? "text-emerald-400"
    : "text-brand-400"
  : "text-red-400";

const heights = {
  sm: "h-1.5",
  md: "h-2",
  lg: "h-3",
};
---

<div class="flex items-center gap-3 w-full">
  <div class:list={["flex-1 bg-surface-700 rounded-full overflow-hidden", heights[size]]}>
    <div
      class:list={["h-full rounded-full transition-all duration-500", barColor]}
      style={`width: ${Math.min(percentage, 100)}%`}
    />
  </div>
  {showLabel && (
    <span class:list={["text-sm font-semibold tabular-nums whitespace-nowrap", textColor]}>
      {percentage}%
    </span>
  )}
</div>
