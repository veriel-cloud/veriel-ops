---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";
import DeployTable from "@/components/DeployTable.astro";
import BuildArtifactRow from "@/components/BuildArtifactRow.astro";
import { deploys, buildArtifacts } from "@/lib/mock-data";

const sortedDeploys = [...deploys].sort(
  (a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime(),
);

const sortedArtifacts = [...buildArtifacts].sort(
  (a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime(),
);

const totalSuccess = deploys.filter((d) => d.status === "success").length;
const totalFailed = deploys.filter((d) => d.status === "failed").length;
const avgDuration = Math.round(deploys.reduce((sum, d) => sum + d.duration, 0) / deploys.length);
---

<DashboardLayout title="Deploys">
  <Header title="Deploys" description="Historial completo de despliegues y builds almacenadas">
    <div slot="actions" class="flex items-center gap-3">
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-surface-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10" cy="10" r="7" /><path d="M21 21l-6 -6" />
        </svg>
        <input type="text" placeholder="Filtrar por proyecto..." class="input pl-9 w-64" />
      </div>
    </div>
  </Header>

  <!-- Quick stats -->
  <div class="grid grid-cols-4 gap-4 mb-8">
    <div class="card p-4">
      <span class="text-xs text-surface-500 uppercase tracking-wider">Total deploys</span>
      <p class="text-2xl font-bold text-white mt-1">{deploys.length}</p>
    </div>
    <div class="card p-4">
      <span class="text-xs text-surface-500 uppercase tracking-wider">Exitosos</span>
      <p class="text-2xl font-bold text-emerald-400 mt-1">{totalSuccess}</p>
    </div>
    <div class="card p-4">
      <span class="text-xs text-surface-500 uppercase tracking-wider">Fallidos</span>
      <p class="text-2xl font-bold text-red-400 mt-1">{totalFailed}</p>
    </div>
    <div class="card p-4">
      <span class="text-xs text-surface-500 uppercase tracking-wider">Duracion media</span>
      <p class="text-2xl font-bold text-white mt-1">{avgDuration}s</p>
    </div>
  </div>

  <!-- Filter tabs -->
  <div class="flex items-center gap-1 mb-6 border-b border-surface-700">
    <button class="px-4 py-2.5 text-sm font-medium text-brand-400 border-b-2 border-brand-400">
      Todos
    </button>
    <button class="px-4 py-2.5 text-sm font-medium text-surface-400 hover:text-surface-200 border-b-2 border-transparent">
      DES
    </button>
    <button class="px-4 py-2.5 text-sm font-medium text-surface-400 hover:text-surface-200 border-b-2 border-transparent">
      PRE
    </button>
    <button class="px-4 py-2.5 text-sm font-medium text-surface-400 hover:text-surface-200 border-b-2 border-transparent">
      PRO
    </button>
    <button class="px-4 py-2.5 text-sm font-medium text-surface-400 hover:text-surface-200 border-b-2 border-transparent">
      Rollbacks
    </button>
  </div>

  <!-- Deploy history table -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-white mb-4">Historial de deploys</h2>
    <div class="card overflow-hidden">
      <DeployTable deploys={sortedDeploys} />
    </div>
  </section>

  <!-- Build artifacts -->
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Builds almacenadas en R2</h2>
      <span class="text-sm text-surface-500">{sortedArtifacts.length} artefactos</span>
    </div>
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-surface-700 text-left">
            <th class="pb-3 pt-4 pl-5 pr-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Proyecto</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Entorno</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Version</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Commit</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Tamano</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Cobertura</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Fecha</th>
            <th class="pb-3 pt-4 px-2 pr-5 text-xs font-medium text-surface-400 uppercase tracking-wider">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {sortedArtifacts.map((artifact) => (
            <BuildArtifactRow artifact={artifact} />
          ))}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>
