---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";
---

<DashboardLayout title="Settings">
  <Header title="Settings" description="Configuracion del sistema veriel-ops" />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- General -->
      <section class="card p-6">
        <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-surface-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.066 2.573c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.573 1.066c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.066 -2.573c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37a1.724 1.724 0 0 0 2.573 -1.066z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
          General
        </h2>
        <div class="space-y-4">
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Organizacion GitHub</label>
            <input type="text" value="veriel-cloud" class="input" readonly />
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Dominio base</label>
            <input type="text" value="veriel.dev" class="input" readonly />
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Cobertura minima global</label>
            <div class="flex items-center gap-2">
              <input type="number" value="80" min="0" max="100" class="input w-24" />
              <span class="text-sm text-surface-500">%</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Cloudflare -->
      <section class="card p-6">
        <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-surface-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6.657 18c-2.572 0 -4.657 -2.007 -4.657 -4.483c0 -2.475 2.085 -4.482 4.657 -4.482c.393 -1.762 1.794 -3.2 3.675 -3.773c1.88 -.572 3.956 -.193 5.444 1c1.488 1.19 2.162 3.007 1.77 4.768h.99c1.913 0 3.464 1.56 3.464 3.486c0 1.927 -1.551 3.487 -3.464 3.487h-11.878" />
          </svg>
          Cloudflare
        </h2>
        <div class="space-y-4">
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Account ID</label>
            <div class="flex items-center gap-2">
              <input type="password" value="••••••••••••••••" class="input flex-1" readonly />
              <button class="btn-ghost btn-sm">Mostrar</button>
            </div>
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Zone ID (veriel.dev)</label>
            <div class="flex items-center gap-2">
              <input type="password" value="••••••••••••••••" class="input flex-1" readonly />
              <button class="btn-ghost btn-sm">Mostrar</button>
            </div>
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">API Token</label>
            <div class="flex items-center gap-2">
              <input type="password" value="••••••••••••••••" class="input flex-1" readonly />
              <span class="badge bg-emerald-500/15 text-emerald-400">Activo</span>
            </div>
          </div>
        </div>
      </section>

      <!-- R2 Storage -->
      <section class="card p-6">
        <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-surface-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 6m-8 0a8 3 0 1 0 16 0a8 3 0 1 0 -16 0" /><path d="M4 6v6a8 3 0 0 0 16 0v-6" /><path d="M4 12v6a8 3 0 0 0 16 0v-6" />
          </svg>
          R2 Storage
        </h2>
        <div class="space-y-4">
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Bucket</label>
            <input type="text" value="veriel-ops-builds" class="input" readonly />
          </div>
          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="text-sm text-surface-400 block mb-1.5">Retencion DES</label>
              <div class="flex items-center gap-2">
                <input type="number" value="10" class="input w-20" />
                <span class="text-xs text-surface-500">builds</span>
              </div>
            </div>
            <div>
              <label class="text-sm text-surface-400 block mb-1.5">Retencion PRE</label>
              <div class="flex items-center gap-2">
                <input type="number" value="20" class="input w-20" />
                <span class="text-xs text-surface-500">builds</span>
              </div>
            </div>
            <div>
              <label class="text-sm text-surface-400 block mb-1.5">Retencion PRO</label>
              <div class="flex items-center gap-2">
                <input type="text" value="∞" class="input w-20 text-center" readonly />
                <span class="text-xs text-surface-500">todas</span>
              </div>
            </div>
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">R2 Access Key</label>
            <div class="flex items-center gap-2">
              <input type="password" value="••••••••••••••••" class="input flex-1" readonly />
              <span class="badge bg-emerald-500/15 text-emerald-400">Activo</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Build Retention -->
      <section class="card p-6">
        <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-surface-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 7l16 0" /><path d="M10 11l0 6" /><path d="M14 11l0 6" /><path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12" /><path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3" />
          </svg>
          Limpieza automatica
        </h2>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm text-surface-200">Limpieza semanal de builds antiguas</p>
              <p class="text-xs text-surface-500 mt-0.5">Se ejecuta cada domingo a las 03:00 UTC</p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" checked class="sr-only peer" />
              <div class="w-11 h-6 bg-surface-700 peer-focus:ring-2 peer-focus:ring-brand-600 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-brand-600"></div>
            </label>
          </div>
        </div>
      </section>
    </div>

    <!-- Sidebar info -->
    <div class="space-y-6">
      <!-- Status -->
      <section class="card p-6">
        <h3 class="text-sm font-semibold text-white mb-4">Estado del sistema</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-surface-400">GitHub API</span>
            <span class="badge bg-emerald-500/15 text-emerald-400">Conectado</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-surface-400">Cloudflare API</span>
            <span class="badge bg-emerald-500/15 text-emerald-400">Conectado</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-surface-400">R2 Storage</span>
            <span class="badge bg-emerald-500/15 text-emerald-400">Conectado</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-surface-400">DNS (veriel.dev)</span>
            <span class="badge bg-emerald-500/15 text-emerald-400">Activo</span>
          </div>
        </div>
      </section>

      <!-- Secrets status -->
      <section class="card p-6">
        <h3 class="text-sm font-semibold text-white mb-4">Secrets de la organizacion</h3>
        <div class="space-y-2">
          {[
            { name: "CLOUDFLARE_API_TOKEN", ok: true },
            { name: "CLOUDFLARE_ACCOUNT_ID", ok: true },
            { name: "CLOUDFLARE_ZONE_ID", ok: true },
            { name: "R2_ACCESS_KEY_ID", ok: true },
            { name: "R2_SECRET_ACCESS_KEY", ok: true },
          ].map((secret) => (
            <div class="flex items-center justify-between py-1">
              <code class="text-xs text-surface-300">{secret.name}</code>
              {secret.ok ? (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12l5 5l10 -10" />
                </svg>
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 6l-12 12" /><path d="M6 6l12 12" />
                </svg>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Workflows -->
      <section class="card p-6">
        <h3 class="text-sm font-semibold text-white mb-4">Workflows disponibles</h3>
        <div class="space-y-2">
          {[
            "ci.yml",
            "deploy-des.yml",
            "deploy-pre.yml",
            "deploy-pro.yml",
            "rollback.yml",
            "setup-dns.yml",
            "cleanup-builds.yml",
          ].map((wf) => (
            <div class="flex items-center gap-2 py-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-surface-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" />
              </svg>
              <code class="text-xs text-surface-300">{wf}</code>
            </div>
          ))}
        </div>
        <a
          href="https://github.com/veriel-cloud/.github"
          target="_blank"
          rel="noopener"
          class="btn-ghost btn-sm w-full justify-center mt-4"
        >
          Ver en GitHub
        </a>
      </section>
    </div>
  </div>
</DashboardLayout>
