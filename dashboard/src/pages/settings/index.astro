---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";

let systemStatus = null;
let error = null;

try {
  const response = await fetch(`${Astro.url.origin}/api/system/status`);
  systemStatus = await response.json();
} catch (e) {
  error = e instanceof Error ? e.message : "Error checking system status";
}
---

<DashboardLayout title="Settings">
  <Header title="Settings" description="Configuracion del sistema veriel-ops" />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- General -->
      <section class="card p-6">
        <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-surface-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.066 2.573c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.573 1.066c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.066 -2.573c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37a1.724 1.724 0 0 0 2.573 -1.066z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
          General
        </h2>
        <div class="space-y-4">
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Organizacion GitHub</label>
            <input type="text" value={import.meta.env.GITHUB_ORG || "veriel-cloud"} class="input" readonly />
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Dominio base</label>
            <input type="text" value="veriel.dev" class="input" readonly />
          </div>
          <div>
            <label class="text-sm text-surface-400 block mb-1.5">Cobertura minima global</label>
            <div class="flex items-center gap-2">
              <input type="number" value="80" min="0" max="100" class="input w-24" />
              <span class="text-sm text-surface-500">%</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Environment variables status -->
      <section class="card p-6">
        <h2 class="text-base font-semibold text-white mb-4 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-surface-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 9v4" /><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.87l-8.106 -13.536a1.914 1.914 0 0 0 -3.274 0z" /><path d="M12 16h.01" />
          </svg>
          Variables de entorno
        </h2>
        <div class="space-y-2">
          {[
            { name: "GITHUB_TOKEN", set: !!import.meta.env.GITHUB_TOKEN },
            { name: "GITHUB_ORG", set: !!import.meta.env.GITHUB_ORG },
            { name: "CLOUDFLARE_API_TOKEN", set: !!import.meta.env.CLOUDFLARE_API_TOKEN },
            { name: "CLOUDFLARE_ACCOUNT_ID", set: !!import.meta.env.CLOUDFLARE_ACCOUNT_ID },
            { name: "CLOUDFLARE_ZONE_ID", set: !!import.meta.env.CLOUDFLARE_ZONE_ID },
            { name: "R2_ACCESS_KEY_ID", set: !!import.meta.env.R2_ACCESS_KEY_ID },
            { name: "R2_SECRET_ACCESS_KEY", set: !!import.meta.env.R2_SECRET_ACCESS_KEY },
            { name: "R2_BUCKET_NAME", set: !!import.meta.env.R2_BUCKET_NAME },
          ].map((env) => (
            <div class="flex items-center justify-between py-1.5">
              <code class="text-xs text-surface-300">{env.name}</code>
              {env.set ? (
                <span class="badge bg-emerald-500/15 text-emerald-400">Configurado</span>
              ) : (
                <span class="badge bg-red-500/15 text-red-400">No configurado</span>
              )}
            </div>
          ))}
        </div>
      </section>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- System status -->
      <section class="card p-6">
        <h3 class="text-sm font-semibold text-white mb-4">Estado del sistema</h3>
        {error && (
          <p class="text-xs text-red-400 mb-3">{error}</p>
        )}
        {systemStatus?.services ? (
          <div class="space-y-3">
            {systemStatus.services.map((service: { name: string; status: string; latency: number }) => (
              <div class="flex items-center justify-between">
                <span class="text-sm text-surface-400">{service.name}</span>
                <div class="flex items-center gap-2">
                  <span class="text-xs text-surface-500">{service.latency}ms</span>
                  <span class:list={[
                    "badge",
                    service.status === "connected"
                      ? "bg-emerald-500/15 text-emerald-400"
                      : "bg-red-500/15 text-red-400",
                  ]}>
                    {service.status === "connected" ? "Conectado" : "Error"}
                  </span>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-xs text-surface-500">No se pudo verificar el estado</p>
        )}
      </section>

      <!-- Workflows -->
      <section class="card p-6">
        <h3 class="text-sm font-semibold text-white mb-4">Workflows disponibles</h3>
        <div class="space-y-2">
          {[
            "ci.yml",
            "deploy-des.yml",
            "deploy-pre.yml",
            "deploy-pro.yml",
            "rollback.yml",
            "setup-dns.yml",
            "cleanup-builds.yml",
          ].map((wf) => (
            <div class="flex items-center gap-2 py-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-surface-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" />
              </svg>
              <code class="text-xs text-surface-300">{wf}</code>
            </div>
          ))}
        </div>
        <a
          href={`https://github.com/${import.meta.env.GITHUB_ORG || "veriel-cloud"}/.github`}
          target="_blank"
          rel="noopener"
          class="btn-ghost btn-sm w-full justify-center mt-4"
        >
          Ver en GitHub
        </a>
      </section>
    </div>
  </div>
</DashboardLayout>
