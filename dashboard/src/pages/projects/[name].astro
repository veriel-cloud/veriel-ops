---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";
import EnvironmentCard from "@/components/EnvironmentCard.astro";
import CoverageBar from "@/components/CoverageBar.astro";
import DeployTable from "@/components/DeployTable.astro";
import BuildArtifactRow from "@/components/BuildArtifactRow.astro";
import { getProjectDetail, formatDate } from "@/lib/data";

const { name } = Astro.params;

let project = null;
let deploys = [];
let builds = [];
let workflowRuns = [];
let error = null;

try {
  const detail = await getProjectDetail(name!);
  project = detail.project;
  deploys = detail.deploys;
  builds = detail.builds;
  workflowRuns = detail.workflowRuns;
} catch (e) {
  error = e instanceof Error ? e.message : "Error loading project";
}

const typeLabels: Record<string, string> = {
  "astro-static": "Astro Static",
  "astro-ssr": "Astro SSR",
  "react-spa": "React SPA",
  "backend-worker": "Worker",
};

const typeColors: Record<string, string> = {
  "astro-static": "bg-orange-500/15 text-orange-400",
  "astro-ssr": "bg-orange-500/15 text-orange-400",
  "react-spa": "bg-cyan-500/15 text-cyan-400",
  "backend-worker": "bg-purple-500/15 text-purple-400",
};
---

<DashboardLayout title={name ?? "Proyecto"}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-surface-500 mb-6">
    <a href="/projects" class="hover:text-surface-300 transition-colors">Proyectos</a>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 6l6 6l-6 6" />
    </svg>
    <span class="text-surface-300">{name}</span>
  </nav>

  {error && (
    <div class="card p-4 mb-8 border-red-500/30 bg-red-500/10">
      <p class="text-sm text-red-400">Error: {error}</p>
    </div>
  )}

  {project && (
    <>
      <Header title={project.name} description={project.domain}>
        <div slot="actions" class="flex items-center gap-3">
          <span class:list={["badge", typeColors[project.type] ?? "bg-surface-700 text-surface-300"]}>
            {typeLabels[project.type] ?? project.type}
          </span>
          {project.customDomain && (
            <span class="badge bg-violet-500/15 text-violet-400">Dominio custom</span>
          )}
          <a
            href={`https://github.com/${project.repo}`}
            target="_blank"
            rel="noopener"
            class="btn-secondary"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
            </svg>
            Repositorio
          </a>
        </div>
      </Header>

      <!-- Project Info Bar -->
      <div class="card p-4 mb-6 flex items-center justify-between">
        <div class="flex items-center gap-8">
          <div>
            <span class="text-xs text-surface-500 block">Creado</span>
            <span class="text-sm text-surface-300">{project.createdAt ? formatDate(project.createdAt) : "—"}</span>
          </div>
          <div>
            <span class="text-xs text-surface-500 block">Umbral cobertura</span>
            <span class="text-sm font-semibold text-white">{project.coverageThreshold}%</span>
          </div>
        </div>
      </div>

      <!-- Environments -->
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-white mb-4">Entornos</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
          {(["des", "pre", "pro"] as const).map((env) => (
            <EnvironmentCard
              environment={env}
              status={project.environments[env]}
              projectName={project.name}
            />
          ))}
        </div>
      </section>

      <!-- Workflow Runs -->
      {workflowRuns.length > 0 && (
        <section class="mb-8">
          <h2 class="text-lg font-semibold text-white mb-4">GitHub Actions</h2>
          <div class="card overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-surface-700 text-left">
                  <th class="pb-3 pt-4 pl-5 pr-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Workflow</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Branch</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Commit</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Estado</th>
                  <th class="pb-3 pt-4 px-2 pr-5 text-xs font-medium text-surface-400 uppercase tracking-wider">Fecha</th>
                </tr>
              </thead>
              <tbody>
                {workflowRuns.slice(0, 10).map((run) => (
                  <tr class="table-row">
                    <td class="py-3 pl-5 pr-2">
                      <a href={run.html_url} target="_blank" rel="noopener" class="font-medium text-surface-200 hover:text-brand-400 transition-colors">
                        {run.name}
                      </a>
                    </td>
                    <td class="py-3 px-2">
                      <code class="text-xs bg-surface-700 px-1.5 py-0.5 rounded text-surface-300">{run.head_branch}</code>
                    </td>
                    <td class="py-3 px-2">
                      <code class="text-xs bg-surface-700 px-1.5 py-0.5 rounded text-surface-300">{run.head_sha?.slice(0, 7)}</code>
                    </td>
                    <td class="py-3 px-2">
                      <span class:list={[
                        "inline-flex items-center gap-1.5 text-xs font-medium",
                        run.conclusion === "success" ? "text-emerald-400" :
                        run.conclusion === "failure" ? "text-red-400" :
                        run.status === "in_progress" ? "text-amber-400" : "text-surface-400",
                      ]}>
                        {run.conclusion === "success" && (
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12l5 5l10 -10" />
                          </svg>
                        )}
                        {run.conclusion === "failure" && (
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6l-12 12" /><path d="M6 6l12 12" />
                          </svg>
                        )}
                        {run.conclusion ?? run.status}
                      </span>
                    </td>
                    <td class="py-3 px-2 pr-5">
                      <span class="text-xs text-surface-400">{formatDate(run.created_at)}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <!-- Deploy History -->
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-white mb-4">Historial de deploys</h2>
        {deploys.length > 0 ? (
          <div class="card overflow-hidden">
            <DeployTable deploys={deploys} showProject={false} />
          </div>
        ) : (
          <div class="card p-8 text-center">
            <p class="text-surface-500">No hay deploys registrados</p>
          </div>
        )}
      </section>

      <!-- Build Artifacts -->
      <section>
        <h2 class="text-lg font-semibold text-white mb-4">Builds almacenadas</h2>
        {builds.length > 0 ? (
          <div class="card overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-surface-700 text-left">
                  <th class="pb-3 pt-4 pl-5 pr-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Entorno</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Version</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Commit</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Tamano</th>
                  <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Fecha</th>
                  <th class="pb-3 pt-4 px-2 pr-5 text-xs font-medium text-surface-400 uppercase tracking-wider">Acciones</th>
                </tr>
              </thead>
              <tbody>
                {builds.map((artifact) => (
                  <BuildArtifactRow artifact={artifact} showProject={false} />
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="card p-8 text-center">
            <p class="text-surface-500">No hay builds almacenadas</p>
          </div>
        )}
      </section>
    </>
  )}
</DashboardLayout>
