---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import CoverageBar from "@/components/CoverageBar.astro";
import EnvironmentBadge from "@/components/EnvironmentBadge.astro";
import { projects, timeAgo } from "@/lib/mock-data";

const typeLabels: Record<string, string> = {
  "astro-static": "Astro Static",
  "astro-ssr": "Astro SSR",
  "react-spa": "React SPA",
  "backend-worker": "Worker",
};
---

<DashboardLayout title="Proyectos">
  <Header title="Proyectos" description={`${projects.length} proyectos registrados`}>
    <div slot="actions" class="flex items-center gap-3">
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-surface-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10" cy="10" r="7" /><path d="M21 21l-6 -6" />
        </svg>
        <input type="text" placeholder="Buscar proyectos..." class="input pl-9 w-64" />
      </div>
      <a href="#" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5l0 14" /><path d="M5 12l14 0" />
        </svg>
        Nuevo proyecto
      </a>
    </div>
  </Header>

  <!-- Grid view -->
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-8">
    {projects.map((project) => (
      <ProjectCard project={project} />
    ))}
  </div>

  <!-- Table view -->
  <section>
    <h2 class="text-lg font-semibold text-white mb-4">Vista detallada</h2>
    <div class="card overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-surface-700 text-left">
            <th class="pb-3 pt-4 pl-5 pr-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Proyecto</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Tipo</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">DES</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">PRE</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">PRO</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider w-40">Cobertura</th>
            <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Dominio</th>
            <th class="pb-3 pt-4 px-2 pr-5 text-xs font-medium text-surface-400 uppercase tracking-wider">Ultimo deploy</th>
          </tr>
        </thead>
        <tbody>
          {projects.map((project) => {
            const mostRecent = Object.values(project.environments)
              .filter((e) => e.lastDeployAt)
              .sort((a, b) => new Date(b.lastDeployAt!).getTime() - new Date(a.lastDeployAt!).getTime())[0];
            return (
              <tr class="table-row">
                <td class="py-3 pl-5 pr-2">
                  <a href={`/projects/${project.name}`} class="font-medium text-surface-200 hover:text-brand-400 transition-colors">
                    {project.name}
                  </a>
                </td>
                <td class="py-3 px-2">
                  <span class="text-xs text-surface-400">{typeLabels[project.type]}</span>
                </td>
                <td class="py-3 px-2">
                  <EnvironmentBadge
                    environment="des"
                    status={project.environments.des.status}
                    compact
                  />
                </td>
                <td class="py-3 px-2">
                  <EnvironmentBadge
                    environment="pre"
                    status={project.environments.pre.status}
                    compact
                  />
                </td>
                <td class="py-3 px-2">
                  <EnvironmentBadge
                    environment="pro"
                    status={project.environments.pro.status}
                    compact
                  />
                </td>
                <td class="py-3 px-2 w-40">
                  <CoverageBar percentage={project.coverage} size="sm" />
                </td>
                <td class="py-3 px-2">
                  <span class="text-xs text-surface-400">{project.domain}</span>
                </td>
                <td class="py-3 px-2 pr-5">
                  <span class="text-xs text-surface-400">
                    {mostRecent?.lastDeployAt ? timeAgo(mostRecent.lastDeployAt) : "—"}
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
</DashboardLayout>
