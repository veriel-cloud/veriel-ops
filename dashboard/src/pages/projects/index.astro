---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import CoverageBar from "@/components/CoverageBar.astro";
import EnvironmentBadge from "@/components/EnvironmentBadge.astro";
import { getProjects, timeAgo } from "@/lib/data";

let projects = [];
let error = null;

try {
  projects = await getProjects();
} catch (e) {
  error = e instanceof Error ? e.message : "Error loading projects";
}

const typeLabels: Record<string, string> = {
  "astro-static": "Astro Static",
  "astro-ssr": "Astro SSR",
  "react-spa": "React SPA",
  "backend-worker": "Worker",
};
---

<DashboardLayout title="Proyectos">
  <Header title="Proyectos" description={`${projects.length} proyectos registrados`}>
    <div slot="actions" class="flex items-center gap-3">
      <a href="/projects/new" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5l0 14" /><path d="M5 12l14 0" />
        </svg>
        Nuevo proyecto
      </a>
    </div>
  </Header>

  {error && (
    <div class="card p-4 mb-8 border-red-500/30 bg-red-500/10">
      <p class="text-sm text-red-400">Error: {error}</p>
    </div>
  )}

  <!-- Grid view -->
  {projects.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-8">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  ) : (
    <div class="card p-12 text-center mb-8">
      <div class="w-16 h-16 mx-auto rounded-full bg-surface-800 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-surface-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 4h3l2 2h5a2 2 0 0 1 2 2v7a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-9a2 2 0 0 1 2 -2" />
        </svg>
      </div>
      <p class="text-surface-400 mb-4">No hay proyectos registrados</p>
      <a href="/projects/new" class="btn-primary inline-flex">Crear primer proyecto</a>
    </div>
  )}

  <!-- Table view -->
  {projects.length > 0 && (
    <section>
      <h2 class="text-lg font-semibold text-white mb-4">Vista detallada</h2>
      <div class="card overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-surface-700 text-left">
              <th class="pb-3 pt-4 pl-5 pr-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Proyecto</th>
              <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Tipo</th>
              <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">DES</th>
              <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">PRE</th>
              <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">PRO</th>
              <th class="pb-3 pt-4 px-2 text-xs font-medium text-surface-400 uppercase tracking-wider">Dominio</th>
              <th class="pb-3 pt-4 px-2 pr-5 text-xs font-medium text-surface-400 uppercase tracking-wider">Creado</th>
            </tr>
          </thead>
          <tbody>
            {projects.map((project) => (
              <tr class="table-row">
                <td class="py-3 pl-5 pr-2">
                  <a href={`/projects/${project.name}`} class="font-medium text-surface-200 hover:text-brand-400 transition-colors">
                    {project.name}
                  </a>
                </td>
                <td class="py-3 px-2">
                  <span class="text-xs text-surface-400">{typeLabels[project.type] ?? project.type}</span>
                </td>
                <td class="py-3 px-2">
                  <EnvironmentBadge environment="des" status={project.environments.des.status} compact />
                </td>
                <td class="py-3 px-2">
                  <EnvironmentBadge environment="pre" status={project.environments.pre.status} compact />
                </td>
                <td class="py-3 px-2">
                  <EnvironmentBadge environment="pro" status={project.environments.pro.status} compact />
                </td>
                <td class="py-3 px-2">
                  <span class="text-xs text-surface-400">{project.domain}</span>
                </td>
                <td class="py-3 px-2 pr-5">
                  <span class="text-xs text-surface-400">
                    {project.createdAt ? timeAgo(project.createdAt) : "—"}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</DashboardLayout>
