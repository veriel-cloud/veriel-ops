---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import Header from "@/components/Header.astro";
---

<DashboardLayout title="Nuevo proyecto">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-surface-500 mb-6">
    <a href="/projects" class="hover:text-surface-300 transition-colors">Proyectos</a>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 6l6 6l-6 6" />
    </svg>
    <span class="text-surface-300">Nuevo proyecto</span>
  </nav>

  <Header title="Nuevo proyecto" description="Registrar un nuevo proyecto en veriel-ops" />

  <div class="max-w-2xl">
    <form id="new-project-form" class="space-y-6">
      <!-- Name -->
      <div class="card p-6 space-y-4">
        <h2 class="text-base font-semibold text-white">Informacion del proyecto</h2>

        <div>
          <label for="name" class="text-sm text-surface-400 block mb-1.5">Nombre del proyecto *</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="mi-proyecto"
            pattern="[a-z0-9-]+"
            class="input"
          />
          <p class="text-xs text-surface-500 mt-1">Solo letras minusculas, numeros y guiones</p>
        </div>

        <div>
          <label for="description" class="text-sm text-surface-400 block mb-1.5">Descripcion</label>
          <input
            type="text"
            id="description"
            name="description"
            placeholder="Descripcion del proyecto"
            class="input"
          />
        </div>

        <div>
          <label for="type" class="text-sm text-surface-400 block mb-1.5">Tipo de proyecto</label>
          <select id="type" name="type" class="input">
            <option value="astro-static">Astro Static</option>
            <option value="astro-ssr">Astro SSR</option>
            <option value="react-spa">React SPA</option>
            <option value="backend-worker">Backend Worker</option>
          </select>
        </div>
      </div>

      <!-- Domain -->
      <div class="card p-6 space-y-4">
        <h2 class="text-base font-semibold text-white">Dominio</h2>

        <div class="flex items-center gap-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="domainType" value="default" checked class="accent-brand-600" />
            <span class="text-sm text-surface-300">Subdominio de veriel.dev</span>
          </label>
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="radio" name="domainType" value="custom" class="accent-brand-600" />
            <span class="text-sm text-surface-300">Dominio custom</span>
          </label>
        </div>

        <div id="default-domain-preview" class="bg-surface-900 rounded-lg p-4">
          <p class="text-xs text-surface-500 mb-2">Se crearan los siguientes subdominios:</p>
          <div class="space-y-1">
            <p class="text-sm text-surface-300">DES: <code class="text-brand-400" id="des-domain">dev.&lt;nombre&gt;.veriel.dev</code></p>
            <p class="text-sm text-surface-300">PRE: <code class="text-amber-400" id="pre-domain">pre.&lt;nombre&gt;.veriel.dev</code></p>
            <p class="text-sm text-surface-300">PRO: <code class="text-emerald-400" id="pro-domain">&lt;nombre&gt;.veriel.dev</code></p>
          </div>
        </div>

        <div id="custom-domain-input" class="hidden">
          <label for="customDomain" class="text-sm text-surface-400 block mb-1.5">Dominio custom</label>
          <input
            type="text"
            id="customDomain"
            name="customDomain"
            placeholder="mi-dominio.com"
            class="input"
          />
          <p class="text-xs text-surface-500 mt-1">El dominio debe estar añadido a Cloudflare previamente</p>
        </div>
      </div>

      <!-- Summary -->
      <div class="card p-6 space-y-4" id="summary-section">
        <h2 class="text-base font-semibold text-white">Resumen</h2>
        <p class="text-sm text-surface-400">Al crear el proyecto se ejecutaran automaticamente:</p>
        <ul class="space-y-2 text-sm text-surface-300">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5l10 -10" />
            </svg>
            Crear repositorio en veriel-cloud
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5l10 -10" />
            </svg>
            Configurar workflows CI/CD
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5l10 -10" />
            </svg>
            Crear branch develop
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5l10 -10" />
            </svg>
            Crear proyecto en Cloudflare Pages
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5l10 -10" />
            </svg>
            Configurar registros DNS
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12l5 5l10 -10" />
            </svg>
            Asociar custom domains
          </li>
        </ul>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <button type="submit" class="btn-primary" id="submit-btn">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3 -5a9 9 0 0 0 6 -8a3 3 0 0 0 -3 -3a9 9 0 0 0 -8 6a6 6 0 0 0 -5 3" />
            <circle cx="15" cy="9" r="1" />
          </svg>
          Crear proyecto
        </button>
        <a href="/projects" class="btn-secondary">Cancelar</a>
      </div>

      <!-- Result -->
      <div id="result" class="hidden"></div>
    </form>
  </div>

  <script>
    const form = document.getElementById("new-project-form") as HTMLFormElement;
    const nameInput = document.getElementById("name") as HTMLInputElement;
    const desDomain = document.getElementById("des-domain") as HTMLElement;
    const preDomain = document.getElementById("pre-domain") as HTMLElement;
    const proDomain = document.getElementById("pro-domain") as HTMLElement;
    const defaultPreview = document.getElementById("default-domain-preview") as HTMLElement;
    const customInput = document.getElementById("custom-domain-input") as HTMLElement;
    const resultDiv = document.getElementById("result") as HTMLElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

    nameInput.addEventListener("input", () => {
      const name = nameInput.value || "<nombre>";
      desDomain.textContent = `dev.${name}.veriel.dev`;
      preDomain.textContent = `pre.${name}.veriel.dev`;
      proDomain.textContent = `${name}.veriel.dev`;
    });

    document.querySelectorAll('input[name="domainType"]').forEach((radio) => {
      radio.addEventListener("change", (e) => {
        const value = (e.target as HTMLInputElement).value;
        defaultPreview.classList.toggle("hidden", value === "custom");
        customInput.classList.toggle("hidden", value === "default");
      });
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = "Creando proyecto...";
      resultDiv.classList.add("hidden");

      const formData = new FormData(form);
      const domainType = formData.get("domainType");

      const body = {
        name: formData.get("name"),
        type: formData.get("type"),
        description: formData.get("description"),
        customDomain: domainType === "custom" ? formData.get("customDomain") : undefined,
      };

      try {
        const response = await fetch("/api/projects", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });

        const data = await response.json();

        if (response.ok) {
          resultDiv.innerHTML = `
            <div class="card p-6 border-emerald-500/30 bg-emerald-500/10">
              <h3 class="text-base font-semibold text-emerald-400 mb-3">Proyecto creado</h3>
              <div class="space-y-2 text-sm">
                <p class="text-surface-300">GitHub: <a href="${data.project.github}" target="_blank" class="text-brand-400 hover:text-brand-300">${data.project.repo}</a></p>
                <p class="text-surface-300">DES: <a href="${data.project.urls.des}" target="_blank" class="text-brand-400 hover:text-brand-300">${data.project.urls.des}</a></p>
                <p class="text-surface-300">PRE: <a href="${data.project.urls.pre}" target="_blank" class="text-brand-400 hover:text-brand-300">${data.project.urls.pre}</a></p>
                <p class="text-surface-300">PRO: <a href="${data.project.urls.pro}" target="_blank" class="text-brand-400 hover:text-brand-300">${data.project.urls.pro}</a></p>
              </div>
              <a href="/projects/${data.project.name}" class="btn-primary mt-4 inline-flex">Ver proyecto</a>
            </div>
          `;
        } else {
          resultDiv.innerHTML = `
            <div class="card p-6 border-red-500/30 bg-red-500/10">
              <p class="text-sm text-red-400">Error: ${data.error}</p>
            </div>
          `;
        }
      } catch (err) {
        resultDiv.innerHTML = `
          <div class="card p-6 border-red-500/30 bg-red-500/10">
            <p class="text-sm text-red-400">Error de conexion</p>
          </div>
        `;
      }

      resultDiv.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Crear proyecto";
    });
  </script>
</DashboardLayout>
