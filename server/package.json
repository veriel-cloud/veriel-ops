{
  "name": "server",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch --env-file=.dev.vars src/index.ts",
    "dev:pretty": "bun --watch --env-file=.dev.vars src/index.ts | pnpm dlx pino-pretty",
    "typecheck": "tsc --noEmit",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest",
    "test:coverage": "vitest run --coverage --exclude 'src/lib/__tests__/db.test.ts' --exclude 'src/services/__tests__/db-store.test.ts' --exclude 'src/middleware/__tests__/auth.test.ts'"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.7.0",
    "octokit": "^5.0.5",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
