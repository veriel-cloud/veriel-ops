{
  "name": "veriel-ops",
  "version": "0.1.0",
  "description": "Sistema centralizado de DevOps para proyectos web de veriel.dev",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:dashboard\"",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm --filter dashboard build && pnpm --filter server build",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "keywords": [
    "devops",
    "cloudflare",
    "ci-cd",
    "deployment"
  ],
  "author": "veriel-dev",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "workerd",
      "esbuild",
      "sharp",
      "lefthook"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "lefthook": "^2.1.4"
  }
}
