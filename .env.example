# ─── Server ───────────────────────────────────────────────
PORT=3001

# Comma-separated origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost,https://tauri.localhost

# Base domain used to derive deploy URLs (project.<base>, project-pre.<base>, ...)
BASE_DOMAIN=example.com

# ─── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_ORG=my-org
GITHUB_WEBHOOK_SECRET=

# ─── Cloudflare ───────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ─── R2 ───────────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ops-builds

# ─── Webhooks ─────────────────────────────────────────────
WEBHOOK_URL=
